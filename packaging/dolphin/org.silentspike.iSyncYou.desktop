[Desktop Entry]
# KF6/Plasma 6 ServiceMenu (modern Type=Application form). NoDisplay keeps it out
# of the application launcher; it only appears in Dolphin's right-click menu.
# MimeType=all/all is the KDE pseudo-type for "every file and folder" — required so
# the menu shows on any selection. (desktop-file-validate does not know this
# KDE-specific pseudo-type and flags it; KDE's own service menus use it too.)
Type=Application
Name=iSyncYou
Icon=folder-sync
Exec=isyncyou dolphin-status %f
MimeType=all/all;
Actions=Status;MakeAvailable;OpenWindow;
X-KDE-Submenu=iSyncYou
X-KDE-Priority=TopLevel
NoDisplay=true

[Desktop Action Status]
Name=Show sync status
Icon=folder-sync
Exec=isyncyou dolphin-status %f

[Desktop Action MakeAvailable]
# Files-on-Demand: download the selected file(s)/folder(s) now instead of on first
# open. %F passes every selected item; a folder is hydrated recursively. Reads route
# through the iSyncYou FUSE mount, so this triggers the batch download notification.
Name=Make available offline (download now)
Icon=cloud-download
Exec=isyncyou make-available %F

[Desktop Action OpenWindow]
Name=Open iSyncYou status window
Icon=folder-sync
Exec=isyncyou-statusbar
