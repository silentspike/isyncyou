<?xml version="1.0" encoding="utf-8"?>
<!-- #89: the standalone app talks HTTPS to Microsoft Graph and plain HTTP only to
     the in-process engine on 127.0.0.1. Cleartext is therefore permitted ONLY for
     loopback; everything else is HTTPS-only (the old global usesCleartextTraffic is
     removed). -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
