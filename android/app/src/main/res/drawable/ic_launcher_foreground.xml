<!-- Adaptive launcher icon foreground (#576): the iSyncYou sync-loop in the brand
     indigo→purple gradient. The glyph is authored in the web-UI's 48-unit space and
     scaled 2.25× so its centre (24,24) lands at the adaptive canvas centre (54,54),
     keeping it inside the 72dp safe zone. Mirrors gui/webui/src/index.html. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="2.25"
        android:scaleY="2.25">
        <path
            android:strokeWidth="3.4"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M16,20 a9,9 0 0 1 16,-3 M32,14 v5 h-5 M32,28 a9,9 0 0 1 -16,3 M16,34 v-5 h5">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="14"
                    android:startY="14"
                    android:endX="34"
                    android:endY="34">
                    <item android:offset="0" android:color="#6366F1" />
                    <item android:offset="1" android:color="#A855F7" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
</vector>
