{
  "issue": 625,
  "commit_under_test": "95db60176a19428e1299f4ec07018cc2fe781f18",
  "scope": "mobile_full_node_server_router_job_contract",
  "native_android_scope": {
    "physical_biometric_prompt": "pending_issue_626",
    "android_keystore_mobile_credential_proof": "pending_issue_626",
    "foreground_service_or_workmanager_presentation": "pending_issue_626",
    "device_recovery_closeout": "pending_issue_626"
  },
  "release_actions": {
    "release_workflow_run": false,
    "manual_tag": false,
    "rc": false,
    "staging_or_main_promotion": false
  },
  "mobile_routes": {
    "restore_cloud": {
      "path": "/api/v1/restore",
      "mobile_behavior": "queued",
      "required_gates": ["session", "restore_capability", "per_action_biometric_token"],
      "job_kind": "restore-cloud",
      "response_shape": ["queued", "job_id", "kind", "state", "service", "restored"]
    },
    "backup": {
      "path": "/api/v1/backup",
      "mobile_behavior": "queued",
      "required_gates": ["session", "backup_capability", "per_action_biometric_token"],
      "job_kind": "backup",
      "response_shape": ["queued", "job_id", "kind", "state", "services"]
    },
    "jobs": {
      "path": "/api/v1/jobs",
      "mobile_behavior": "status_and_cancel",
      "required_gates": ["session", "mobile_job_capability"]
    }
  },
  "agent_confirm_order": [
    "session gate",
    "agent capability gate",
    "parse pending/token/action_hash",
    "non-consuming PendingAction binding lookup",
    "per-action biometric-token challenge",
    "consume Agent one-time token",
    "execute confirmed operation"
  ],
  "mobile_agent_operations": {
    "backup": "enqueue_mobile_job",
    "restore_cloud": "enqueue_mobile_job",
    "share": "ledger_backed_share_handler",
    "live_write": {
      "allowed": [
        "mail:set_read",
        "mail:set_flag",
        "mail:set_categories",
        "todo:complete",
        "todo:checklist_toggle"
      ],
      "unsupported_verbs": "fail_closed"
    }
  },
  "mobile_job_runtime": {
    "storage": "store mobile_jobs table",
    "states": ["queued", "running", "succeeded", "failed", "cancelled"],
    "lease_recovery": "queued and expired running jobs are recoverable",
    "dedupe": "open jobs are deduped by account/kind/idempotency_key",
    "terminal_retry": "terminal jobs do not block a later user retry",
    "cancel_semantics": "cancel marks queued/running jobs cancelled; late worker success is reconciled before accepting final state"
  },
  "proof_tests": [
    "mobile_full_node_router_exposes_gated_restore_and_backup",
    "standalone_full_node_serves_ui_and_gates_restore_backup",
    "mobile_full_node_restore_backup_do_not_run_without_biometric_token",
    "mobile_full_node_job_recovery_runs_on_start",
    "mobile_backup_job_enqueue_only_worker_executes_later",
    "mobile_restore_cloud_job_recovery_after_running_lease_expiry_reconciles",
    "mobile_job_worker_does_not_duplicate_restore_after_restart",
    "mobile_agent_confirm_requires_biometric_before_agent_token_consumption",
    "mobile_live_write_allowlist_accepts_only_metadata_verbs",
    "mobile_live_write_disallowed_create_send_delete_append_verbs_fail_closed"
  ]
}
