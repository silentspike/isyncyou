# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# --- iSyncYou: internal / never commit ---
.claude/
llm-*.log
llm-*.md
/scratch/
/fixtures/
.cargo-remote.toml
*.db
*.sqlite
.env
.DS_Store

# Browser-automation + LLM scratch artifacts (never committed)
.playwright-cli/
llm-*.log

# Python bytecode cache from the tooling under tools/ (e.g. check_language.py)
__pycache__/
*.pyc

# Generated (HEAD-pinned) evidence manifest — produced by tools/generate_evidence_manifest.py
# as a CI artifact; the curated docs/evidence/sample-manifest.json is the committed source.
/docs/evidence/generated-manifest.json

# --- Secrets, tokens, credentials: NEVER commit (defense-in-depth) ---
# OAuth/MSAL token caches live in $HOME (~/.config/m365-{read,write}/token_cache.json),
# never in the repo — but ignore them defensively in case anything is copied in.
*token_cache*.json
token_cache.json
*.token
# env files (any variant)
.env
.env.*
*.env
# private keys / certs / keystores
*.key
*.pem
*.p12
*.pfx
*.ppk
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
# credential / secret blobs (extension-anchored so they never match source or secret-scan.yml)
*.secret
secrets.json
secrets.toml
secrets.yaml
*.secrets.json
*credential*.json
*credential*.toml
# PBS / storage password files + machine netrc
*.pw
.netrc
.npmrc

# --- Internal notes / scratch docs: never commit (the repo ships only public docs) ---
# Public docs are explicit (README/CONTRIBUTING/SECURITY/CHANGELOG/CODE_OF_CONDUCT and
# docs/**). Internal planning/session/scratch notes stay local.
SHOWCASE.md
/docs/case-study/
# German-language internal field-coverage worktable (the committed public sibling
# is the English docs/graph-capability-matrix.md).
/docs/GRAPH-FIELD-COVERAGE.md
*.local.md
*-internal.md
*.internal.md
SCRATCH.md
NOTES.local.md
/notes/
PLAN-*.md
SESSION-*.md
HANDOFF*.md
TODO.local.md

# Dolphin KIO plugin local build dir (host-built, never committed)
packaging/dolphin/overlay-plugin/build/

# user-supplied credentials (never committed)
.secrets/
